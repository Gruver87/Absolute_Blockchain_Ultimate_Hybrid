# Absolute Blockchain Ultimate — Environment Variables
# Copy to .env (optional). Never commit .env with real secrets.
#
# Tokenomics (educational model):
#   221,000,000 ABS max supply
#   Founder D.U.P. (Uladzimir Dabranski) — 17.4% = 38,454,000 ABS

# Weather oracles (optional — без ключей оракулы работают в demo-режиме)
OPENWEATHER_API_KEY=your_api_key_here
WEATHERAPI_KEY=your_api_key_here

# Telegram Bot Token (optional — бот узла, не автопост)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# GitHub PAT for gh CLI / push (local .env only, never commit)
GITHUB_TOKEN=

# ECDSA private key (64 hex) — local .env only, never commit
WALLET_PRIVATE_KEY=

# Chain integrity (prod / node.example.json: true)
REQUIRE_SIGNATURES=false
ENFORCE_PROPOSER=true
VERIFY_PEER_STATE_ROOT=true
STATE_ROOT_STRICT_P2P=true

# JWT Secret (optional, API auth)
JWT_SECRET=your_jwt_secret_here

# Network ports (defaults match runtime/config.py)
RPC_PORT=8545
HTTP_PORT=8080
WS_PORT=8766
P2P_PORT=5000

# Industrial profile (optional)
DEPLOYMENT_MODE=dev
NODE_ID=node-1
DATA_DIR=./data
LOG_LEVEL=INFO
LOG_JSON=false
METRICS_ENABLED=true
JWT_ENFORCE_ADMIN=false
REQUIRE_WALLET_FILE=false
ENABLE_CORS_RPC_PROXY=true
CORS_ORIGINS=*
SQLITE_SYNCHRONOUS=NORMAL

# HA / Scale (Phase 5)
REDIS_URL=redis://localhost:6379/0
REDIS_RATE_LIMIT=false
RATE_LIMIT_RPM=120
BOOTSTRAP_PEERS=

# Bridge (default: rust production path; simulator = explicit dev/test only)
BRIDGE_ENABLED=true
BRIDGE_MODE=rust
BRIDGE_AUTO_CONFIRM_SEC=0
RUST_BRIDGE_PATH=bridge/abs_bridge_bin
BRIDGE_ORACLE_SECRET=your_bridge_oracle_hmac_secret
BRIDGE_REQUIRE_L1_PROOF=false
BRIDGE_PROBE_L1_RPC=false
BRIDGE_L1_QUEUE_PATH=data/bridge_l1_queue.json
BRIDGE_MIN_CONFIRMATIONS=12
ETH_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=

# Docker prod quick setup (generates .env locally, never commit):
#   powershell -File scripts/setup_prod_env.ps1
#   powershell -File scripts/docker_prod.ps1

# Telegram bot (optional)
ABS_API_URL=http://localhost:8080
ABS_JWT=
TELEGRAM_ADMIN_CHAT_IDS=
CHAIN_ID=77777

# RPC API keys (prod) — generate: python scripts/generate_rpc_key.py
RPC_API_KEY_REQUIRED=false
RPC_API_KEYS=

# Validator signing (prod) — local wallet default; external HSM/KMS for mainnet
VALIDATOR_KEY_PROVIDER=local
EXTERNAL_VALIDATOR_SIGNER_URL=
EXTERNAL_VALIDATOR_SIGNER_API_KEY=
AWS_KMS_KEY_ID=
AWS_REGION=us-east-1
GCP_KMS_KEY_VERSION=
GCP_PROJECT_ID=
GCP_KMS_LOCATION=global
GCP_KMS_KEY_RING=
GCP_KMS_KEY_NAME=
GCP_KMS_KEY_VERSION_ID=1
# GCP Cloud HSM (KMS key with protection_level=HSM): VALIDATOR_KEY_PROVIDER=gcp_cloudhsm
