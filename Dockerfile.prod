# syntax=docker/dockerfile:1
# Prod image with Rust bridge binary (staging/prod profile).
# Enable BuildKit for cache mounts: DOCKER_BUILDKIT=1
FROM rust:1-bookworm AS rust-build
WORKDIR /build

# Bridge: prefetch deps (cached layer when lockfile unchanged)
COPY bridge/rust_bridge/Cargo.toml bridge/rust_bridge/Cargo.lock ./
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    cargo fetch --locked

COPY bridge/rust_bridge/src ./src
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/build/target \
    cargo build --release --locked \
    && cp target/release/abs_bridge_bin /abs_bridge_bin

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
     python3 python3-pip \
     clang libclang-dev cmake pkg-config \
     libsnappy-dev zlib1g-dev libbz2-dev liblz4-dev libzstd-dev \
  && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --break-system-packages --no-cache-dir maturin

WORKDIR /build/native/abs_native
COPY native/abs_native/Cargo.toml native/abs_native/Cargo.lock ./
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    cargo fetch --locked

COPY native/abs_native/pyproject.toml native/abs_native/Cargo.toml native/abs_native/Cargo.lock ./
COPY native/abs_native/src ./src
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/build/native/abs_native/target \
    python3 -m maturin build --release --out /wheels

FROM python:3.13-slim

WORKDIR /app

ENV PYTHONUTF8=1
ENV PYTHONIOENCODING=utf-8
ENV PYTHONUNBUFFERED=1
ENV ABS_REQUIRE_NATIVE_CRYPTO=true

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
COPY --from=rust-build /abs_bridge_bin /app/bridge/abs_bridge_bin
COPY --from=rust-build /wheels /wheels
RUN pip install --no-cache-dir /wheels/*.whl \
  && python -c "import abs_native; assert hasattr(abs_native, 'RocksEngine'); from crypto import native; s=native.native_crypto_status(required=True); assert s['available'] and s['self_test'], s; print('abs_native OK (rocksdb)')"
RUN chmod +x /app/bridge/abs_bridge_bin

EXPOSE 8545 8080 5000 8766

HEALTHCHECK --interval=30s --timeout=5s --start-period=45s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8080/health/ready', timeout=3)"

CMD ["python", "main.py", "--config", "docker/node.prod.json"]
