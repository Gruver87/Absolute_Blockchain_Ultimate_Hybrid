{
  "node_id": "mainnet-v1-node-1",
  "network_name": "Absolute Mainnet",
  "chain_id": 778888,
  "deployment_mode": "prod",
  "http_host": "0.0.0.0",
  "rpc_host": "0.0.0.0",
  "ws_host": "0.0.0.0",
  "p2p_host": "0.0.0.0",
  "p2p_port": 5000,
  "http_port": 8080,
  "rpc_port": 8545,
  "ws_port": 8766,
  "p2p_max_message_bytes": 2097152,
  "p2p_max_messages_per_sec": 500,
  "p2p_ban_seconds": 300,
  "p2p_rate_limit_strikes": 5,
  "p2p_evict_min_score": 0,
  "p2p_tls_enabled": true,
  "p2p_tls_cert_path": "data/p2p_tls/node.pem",
  "p2p_tls_key_path": "data/p2p_tls/node.key",
  "p2p_tls_ca_path": "data/p2p_tls/ca.pem",
  "p2p_tls_require_client_cert": true,
  "p2p_tls_fail_closed": true,
  "p2p_tls_bind_identity": true,
  "bootstrap_peers": [],
  "mining_enabled": true,
  "require_signatures": true,
  "require_native_crypto": true,
  "enforce_proposer": true,
  "verify_peer_state_root": true,
  "state_root_strict_p2p": true,
  "state_root_legacy_cutoff_height": 0,
  "bridge_enabled": false,
  "bridge_mode": "rust",
  "bridge_require_l1_proof": true,
  "evm_create2_eip1014": true,
  "evm_require_deploy_salt": true,
  "rate_limit_rpm": 120,
  "rpc_api_key_required": true,
  "jwt_enforce_admin": true,
  "require_wallet_file": true,
  "consensus_mode": "unified",
  "feature_zk": false,
  "feature_sharding": false,
  "feature_oracles": false,
  "feature_wasm": false,
  "feature_plasma": false,
  "feature_lightning": false,
  "feature_pq": false,
  "feature_mev": false,
  "feature_ai_agents": false,
  "feature_ai_validator": false,
  "sqlite_synchronous": "FULL",
  "db_engine": "rocksdb",
  "rocksdb_sync": "FULL",
  "rocksdb_block_cache_mb": 256,
  "rocksdb_write_buffer_mb": 64,
  "rocksdb_column_families": false,
  "log_json": true,
  "enable_cors_rpc_proxy": false,
  "cors_origins": [
    "https://your-explorer.example.com"
  ],
  "db_path": "data/blockchain.db",
  "log_file": "data/node.log",
  "validators_manifest_path": "validators.manifest.mainnet-v1.example.json",
  "rust_bridge_path": "bridge/abs_bridge_bin",
  "bridge_auto_confirm_sec": 0
}
