# Bridge L1 mainnet cutover — copy to .env before enabling bridge on prod.
# Never commit real secrets. ETH_RPC_URL and contract addresses via env only.

# --- L1 RPC (required for cutover) ---
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_API_KEY
# Optional multi-chain:
# BSC_RPC_URL=
# POLYGON_RPC_URL=

# --- L1 contracts (set after audited deploy; placeholders fail --probe-l1) ---
BRIDGE_L1_CHAIN=ethereum
BRIDGE_L1_LOCK_CONTRACT=0x0000000000000000000000000000000000000000
BRIDGE_L1_MINT_CONTRACT=0x0000000000000000000000000000000000000000

# --- Bridge runtime (prod) ---
BRIDGE_ENABLED=true
BRIDGE_MODE=rust
RUST_BRIDGE_PATH=bridge/abs_bridge_bin
BRIDGE_REQUIRE_L1_PROOF=true
BRIDGE_PROBE_L1_RPC=true
BRIDGE_ORACLE_SECRET=rotate_me_before_cutover
BRIDGE_L1_QUEUE_PATH=data/bridge_l1_queue.json
BRIDGE_MIN_CONFIRMATIONS=12

# NEVER set in production:
# BRIDGE_ALLOW_SYNTHETIC=true
